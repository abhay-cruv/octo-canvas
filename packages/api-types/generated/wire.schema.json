{"$schema": "http://json-schema.org/draft-07/schema#", "title": "OctoCanvasWireProtocol", "definitions": {"BackpressureWarning": {"description": "Emitted when the per-subscriber outbound queue overflows. The web\nclient's reconnect logic should treat this as a hint to bump its replay\ncursor and `Resume` from `last_dropped_seq` on next reconnect.", "properties": {"type": {"const": "backpressure.warning", "default": "backpressure.warning", "title": "Type", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "last_dropped_seq": {"title": "Last Dropped Seq", "type": "integer"}}, "required": ["seq", "last_dropped_seq"], "title": "BackpressureWarning", "type": "object"}, "DebugEvent": {"description": "Slice 5a only \u2014 produced by the dev-only `/api/_internal/...` inject\nendpoint. The full agent event taxonomy replaces this in slice 6+.", "properties": {"type": {"const": "debug.event", "default": "debug.event", "title": "Type", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "message": {"title": "Message", "type": "string"}}, "required": ["seq", "message"], "title": "DebugEvent", "type": "object"}, "ErrorEvent": {"properties": {"type": {"const": "error", "default": "error", "title": "Type", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "kind": {"title": "Kind", "type": "string"}, "message": {"title": "Message", "type": "string"}}, "required": ["seq", "kind", "message"], "title": "ErrorEvent", "type": "object"}, "Pong": {"description": "Reply to a `Ping` from the web client. Carries `nonce` for correlation\nso the web side can compute round-trip latency. No `seq` \u2014 system frame.", "properties": {"type": {"const": "pong", "default": "pong", "title": "Type", "type": "string"}, "nonce": {"title": "Nonce", "type": "string"}}, "required": ["nonce"], "title": "Pong", "type": "object"}, "SandboxStatusEvent": {"properties": {"type": {"const": "sandbox.status", "default": "sandbox.status", "title": "Type", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "sandbox_id": {"title": "Sandbox Id", "type": "string"}, "status": {"enum": ["provisioning", "cold", "warm", "running", "resetting", "destroyed", "failed"], "title": "Status", "type": "string"}, "public_url": {"anyOf": [{"type": "string"}, {"type": "null"}], "default": null, "title": "Public Url"}}, "required": ["seq", "sandbox_id", "status"], "title": "SandboxStatusEvent", "type": "object"}, "ServerPing": {"description": "Server-initiated heartbeat. The web client must reply with `Pong` (see\n`commands.py`). No `seq` \u2014 system frame.", "properties": {"type": {"const": "ping", "default": "ping", "title": "Type", "type": "string"}, "nonce": {"title": "Nonce", "type": "string"}}, "required": ["nonce"], "title": "ServerPing", "type": "object"}, "StatusChangeEvent": {"properties": {"type": {"const": "status.change", "default": "status.change", "title": "Type", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "new_status": {"enum": ["pending", "running", "completed", "failed", "cancelled"], "title": "New Status", "type": "string"}}, "required": ["seq", "new_status"], "title": "StatusChangeEvent", "type": "object"}, "ClientPing": {"properties": {"type": {"const": "ping", "default": "ping", "title": "Type", "type": "string"}, "nonce": {"title": "Nonce", "type": "string"}}, "required": ["nonce"], "title": "ClientPing", "type": "object"}, "ClientPong": {"properties": {"type": {"const": "pong", "default": "pong", "title": "Type", "type": "string"}, "nonce": {"title": "Nonce", "type": "string"}}, "required": ["nonce"], "title": "ClientPong", "type": "object"}, "Resume": {"description": "Sent as the FIRST frame of every (re)connection. The orchestrator\nstreams every event with `seq > after_seq` from Mongo, then transitions\nto live mode by subscribing to the per-task fanout channel.", "properties": {"type": {"const": "resume", "default": "resume", "title": "Type", "type": "string"}, "after_seq": {"title": "After Seq", "type": "integer"}}, "required": ["after_seq"], "title": "Resume", "type": "object"}, "FileEditEvent": {"description": "One filesystem change observed inside the sandbox. Emitted by the\norchestrator's fs-watch broker after coalescing per [Plan.md \u00a710.6].", "properties": {"type": {"const": "file.edit", "default": "file.edit", "title": "Type", "type": "string"}, "path": {"title": "Path", "type": "string"}, "kind": {"enum": ["create", "modify", "delete", "rename"], "title": "Kind", "type": "string"}, "is_dir": {"default": false, "title": "Is Dir", "type": "boolean"}, "size": {"anyOf": [{"type": "integer"}, {"type": "null"}], "default": null, "title": "Size"}, "timestamp_ms": {"title": "Timestamp Ms", "type": "integer"}}, "required": ["path", "kind", "timestamp_ms"], "title": "FileEditEvent", "type": "object"}, "FsWatchSubscribed": {"description": "Sent immediately after the channel handshake completes so the FE has\na deterministic point to remove its 'connecting\u2026' state.", "properties": {"type": {"const": "fswatch.subscribed", "default": "fswatch.subscribed", "title": "Type", "type": "string"}, "sandbox_id": {"title": "Sandbox Id", "type": "string"}, "root_path": {"title": "Root Path", "type": "string"}}, "required": ["sandbox_id", "root_path"], "title": "FsWatchSubscribed", "type": "object"}, "RequestClosePty": {"description": "Web \u2192 orchestrator: kill this PTY (the user closed the terminal tab).\nThe orchestrator drops its Sprites Exec session and clears the Redis\nreattach record.", "properties": {"type": {"const": "pty.close", "default": "pty.close", "title": "Type", "type": "string"}, "terminal_id": {"title": "Terminal Id", "type": "string"}}, "required": ["terminal_id"], "title": "RequestClosePty", "type": "object"}, "RequestOpenPty": {"description": "Reserved for a future task-WS-driven PTY open. Slice 6 opens PTYs by\ndialling the per-PTY URL directly; this frame is unused on the wire\nuntil the task WS gains PTY-control responsibilities.", "properties": {"type": {"const": "pty.open", "default": "pty.open", "title": "Type", "type": "string"}, "sandbox_id": {"title": "Sandbox Id", "type": "string"}, "terminal_id": {"title": "Terminal Id", "type": "string"}, "cwd": {"anyOf": [{"type": "string"}, {"type": "null"}], "default": null, "title": "Cwd"}, "cols": {"default": 80, "title": "Cols", "type": "integer"}, "rows": {"default": 24, "title": "Rows", "type": "integer"}}, "required": ["sandbox_id", "terminal_id"], "title": "RequestOpenPty", "type": "object"}, "ResizePty": {"description": "Web \u2192 orchestrator: tell the underlying PTY its new dimensions. The\norchestrator forwards verbatim to Sprites' Exec channel.", "properties": {"type": {"const": "pty.resize", "default": "pty.resize", "title": "Type", "type": "string"}, "cols": {"maximum": 10000, "minimum": 1, "title": "Cols", "type": "integer"}, "rows": {"maximum": 10000, "minimum": 1, "title": "Rows", "type": "integer"}}, "required": ["cols", "rows"], "title": "ResizePty", "type": "object"}, "PtyExit": {"description": "Orchestrator \u2192 web: the upstream shell exited. The web side typically\nleaves the tab open so the user can read final output, then closes the\nsocket on user action.", "properties": {"type": {"const": "pty.exit", "default": "pty.exit", "title": "Type", "type": "string"}, "terminal_id": {"title": "Terminal Id", "type": "string"}, "exit_code": {"title": "Exit Code", "type": "integer"}}, "required": ["terminal_id", "exit_code"], "title": "PtyExit", "type": "object"}, "PtySessionInfo": {"description": "Orchestrator \u2192 web: emitted once after the upstream Sprites Exec\nsession is up. Mirrors Sprites' `session_info` plus the orchestrator's\nown correlation id so reattach can be reasoned about end-to-end.", "properties": {"type": {"const": "pty.session_info", "default": "pty.session_info", "title": "Type", "type": "string"}, "terminal_id": {"title": "Terminal Id", "type": "string"}, "sprites_session_id": {"title": "Sprites Session Id", "type": "string"}, "cols": {"title": "Cols", "type": "integer"}, "rows": {"title": "Rows", "type": "integer"}, "reattached": {"title": "Reattached", "type": "boolean"}}, "required": ["terminal_id", "sprites_session_id", "cols", "rows", "reattached"], "title": "PtySessionInfo", "type": "object"}, "OrchestratorToWeb": {"discriminator": {"mapping": {"backpressure.warning": "#/definitions/BackpressureWarning", "debug.event": "#/definitions/DebugEvent", "error": "#/definitions/ErrorEvent", "ping": "#/definitions/ServerPing", "pong": "#/definitions/Pong", "sandbox.status": "#/definitions/SandboxStatusEvent", "status.change": "#/definitions/StatusChangeEvent"}, "propertyName": "type"}, "oneOf": [{"$ref": "#/definitions/StatusChangeEvent"}, {"$ref": "#/definitions/SandboxStatusEvent"}, {"$ref": "#/definitions/ErrorEvent"}, {"$ref": "#/definitions/BackpressureWarning"}, {"$ref": "#/definitions/DebugEvent"}, {"$ref": "#/definitions/Pong"}, {"$ref": "#/definitions/ServerPing"}]}, "WebToOrchestrator": {"discriminator": {"mapping": {"ping": "#/definitions/ClientPing", "pong": "#/definitions/ClientPong", "resume": "#/definitions/Resume"}, "propertyName": "type"}, "oneOf": [{"$ref": "#/definitions/Resume"}, {"$ref": "#/definitions/ClientPing"}, {"$ref": "#/definitions/ClientPong"}]}, "FsWatchToWeb": {"discriminator": {"mapping": {"file.edit": "#/definitions/FileEditEvent", "fswatch.subscribed": "#/definitions/FsWatchSubscribed"}, "propertyName": "type"}, "oneOf": [{"$ref": "#/definitions/FileEditEvent"}, {"$ref": "#/definitions/FsWatchSubscribed"}]}, "WebToPty": {"discriminator": {"mapping": {"pty.close": "#/definitions/RequestClosePty", "pty.open": "#/definitions/RequestOpenPty", "pty.resize": "#/definitions/ResizePty"}, "propertyName": "type"}, "oneOf": [{"$ref": "#/definitions/ResizePty"}, {"$ref": "#/definitions/RequestOpenPty"}, {"$ref": "#/definitions/RequestClosePty"}]}, "PtyToWeb": {"discriminator": {"mapping": {"pty.exit": "#/definitions/PtyExit", "pty.session_info": "#/definitions/PtySessionInfo"}, "propertyName": "type"}, "oneOf": [{"$ref": "#/definitions/PtySessionInfo"}, {"$ref": "#/definitions/PtyExit"}]}}}
