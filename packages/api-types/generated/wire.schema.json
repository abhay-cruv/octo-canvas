{"$schema": "http://json-schema.org/draft-07/schema#", "title": "OctoCanvasWireProtocol", "definitions": {"BackpressureWarning": {"description": "Emitted when the per-subscriber outbound queue overflows. The web\nclient's reconnect logic should treat this as a hint to bump its replay\ncursor and `Resume` from `last_dropped_seq` on next reconnect.", "properties": {"type": {"const": "backpressure.warning", "default": "backpressure.warning", "title": "Type", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "last_dropped_seq": {"title": "Last Dropped Seq", "type": "integer"}}, "required": ["seq", "last_dropped_seq"], "title": "BackpressureWarning", "type": "object"}, "DebugEvent": {"description": "Slice 5a only \u2014 produced by the dev-only `/api/_internal/...` inject\nendpoint. The full agent event taxonomy replaces this in slice 6+.", "properties": {"type": {"const": "debug.event", "default": "debug.event", "title": "Type", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "message": {"title": "Message", "type": "string"}}, "required": ["seq", "message"], "title": "DebugEvent", "type": "object"}, "ErrorEvent": {"properties": {"type": {"const": "error", "default": "error", "title": "Type", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "kind": {"title": "Kind", "type": "string"}, "message": {"title": "Message", "type": "string"}}, "required": ["seq", "kind", "message"], "title": "ErrorEvent", "type": "object"}, "Pong": {"description": "Reply to a `Ping` from the web client. Carries `nonce` for correlation\nso the web side can compute round-trip latency. No `seq` \u2014 system frame.", "properties": {"type": {"const": "pong", "default": "pong", "title": "Type", "type": "string"}, "nonce": {"title": "Nonce", "type": "string"}}, "required": ["nonce"], "title": "Pong", "type": "object"}, "SandboxStatusEvent": {"properties": {"type": {"const": "sandbox.status", "default": "sandbox.status", "title": "Type", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "sandbox_id": {"title": "Sandbox Id", "type": "string"}, "status": {"enum": ["provisioning", "cold", "warm", "running", "resetting", "destroyed", "failed"], "title": "Status", "type": "string"}, "public_url": {"anyOf": [{"type": "string"}, {"type": "null"}], "default": null, "title": "Public Url"}}, "required": ["seq", "sandbox_id", "status"], "title": "SandboxStatusEvent", "type": "object"}, "ServerPing": {"description": "Server-initiated heartbeat. The web client must reply with `Pong` (see\n`commands.py`). No `seq` \u2014 system frame.", "properties": {"type": {"const": "ping", "default": "ping", "title": "Type", "type": "string"}, "nonce": {"title": "Nonce", "type": "string"}}, "required": ["nonce"], "title": "ServerPing", "type": "object"}, "StatusChangeEvent": {"properties": {"type": {"const": "status.change", "default": "status.change", "title": "Type", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "new_status": {"enum": ["pending", "running", "completed", "failed", "cancelled"], "title": "New Status", "type": "string"}}, "required": ["seq", "new_status"], "title": "StatusChangeEvent", "type": "object"}, "ClientPing": {"properties": {"type": {"const": "ping", "default": "ping", "title": "Type", "type": "string"}, "nonce": {"title": "Nonce", "type": "string"}}, "required": ["nonce"], "title": "ClientPing", "type": "object"}, "ClientPong": {"properties": {"type": {"const": "pong", "default": "pong", "title": "Type", "type": "string"}, "nonce": {"title": "Nonce", "type": "string"}}, "required": ["nonce"], "title": "ClientPong", "type": "object"}, "Resume": {"description": "Sent as the FIRST frame of every (re)connection. The orchestrator\nstreams every event with `seq > after_seq` from Mongo, then transitions\nto live mode by subscribing to the per-task fanout channel.", "properties": {"type": {"const": "resume", "default": "resume", "title": "Type", "type": "string"}, "after_seq": {"title": "After Seq", "type": "integer"}}, "required": ["after_seq"], "title": "Resume", "type": "object"}, "FileEditEvent": {"description": "One filesystem change observed inside the sandbox. Emitted by the\norchestrator's fs-watch broker after coalescing per [Plan.md \u00a710.6].", "properties": {"type": {"const": "file.edit", "default": "file.edit", "title": "Type", "type": "string"}, "path": {"title": "Path", "type": "string"}, "kind": {"enum": ["create", "modify", "delete", "rename"], "title": "Kind", "type": "string"}, "is_dir": {"default": false, "title": "Is Dir", "type": "boolean"}, "size": {"anyOf": [{"type": "integer"}, {"type": "null"}], "default": null, "title": "Size"}, "timestamp_ms": {"title": "Timestamp Ms", "type": "integer"}}, "required": ["path", "kind", "timestamp_ms"], "title": "FileEditEvent", "type": "object"}, "FsWatchSubscribed": {"description": "Sent immediately after the channel handshake completes so the FE has\na deterministic point to remove its 'connecting\u2026' state.", "properties": {"type": {"const": "fswatch.subscribed", "default": "fswatch.subscribed", "title": "Type", "type": "string"}, "sandbox_id": {"title": "Sandbox Id", "type": "string"}, "root_path": {"title": "Root Path", "type": "string"}}, "required": ["sandbox_id", "root_path"], "title": "FsWatchSubscribed", "type": "object"}, "RequestClosePty": {"description": "Web \u2192 orchestrator: kill this PTY (the user closed the terminal tab).\nThe orchestrator drops its Sprites Exec session and clears the Redis\nreattach record.", "properties": {"type": {"const": "pty.close", "default": "pty.close", "title": "Type", "type": "string"}, "terminal_id": {"title": "Terminal Id", "type": "string"}}, "required": ["terminal_id"], "title": "RequestClosePty", "type": "object"}, "RequestOpenPty": {"description": "Reserved for a future task-WS-driven PTY open. Slice 6 opens PTYs by\ndialling the per-PTY URL directly; this frame is unused on the wire\nuntil the task WS gains PTY-control responsibilities.", "properties": {"type": {"const": "pty.open", "default": "pty.open", "title": "Type", "type": "string"}, "sandbox_id": {"title": "Sandbox Id", "type": "string"}, "terminal_id": {"title": "Terminal Id", "type": "string"}, "cwd": {"anyOf": [{"type": "string"}, {"type": "null"}], "default": null, "title": "Cwd"}, "cols": {"default": 80, "title": "Cols", "type": "integer"}, "rows": {"default": 24, "title": "Rows", "type": "integer"}}, "required": ["sandbox_id", "terminal_id"], "title": "RequestOpenPty", "type": "object"}, "ResizePty": {"description": "Web \u2192 orchestrator: tell the underlying PTY its new dimensions. The\norchestrator forwards verbatim to Sprites' Exec channel.", "properties": {"type": {"const": "pty.resize", "default": "pty.resize", "title": "Type", "type": "string"}, "cols": {"maximum": 10000, "minimum": 1, "title": "Cols", "type": "integer"}, "rows": {"maximum": 10000, "minimum": 1, "title": "Rows", "type": "integer"}}, "required": ["cols", "rows"], "title": "ResizePty", "type": "object"}, "PtyExit": {"description": "Orchestrator \u2192 web: the upstream shell exited. The web side typically\nleaves the tab open so the user can read final output, then closes the\nsocket on user action.", "properties": {"type": {"const": "pty.exit", "default": "pty.exit", "title": "Type", "type": "string"}, "terminal_id": {"title": "Terminal Id", "type": "string"}, "exit_code": {"title": "Exit Code", "type": "integer"}}, "required": ["terminal_id", "exit_code"], "title": "PtyExit", "type": "object"}, "PtySessionInfo": {"description": "Orchestrator \u2192 web: emitted once after the upstream Sprites Exec\nsession is up. Mirrors Sprites' `session_info` plus the orchestrator's\nown correlation id so reattach can be reasoned about end-to-end.", "properties": {"type": {"const": "pty.session_info", "default": "pty.session_info", "title": "Type", "type": "string"}, "terminal_id": {"title": "Terminal Id", "type": "string"}, "sprites_session_id": {"title": "Sprites Session Id", "type": "string"}, "cols": {"title": "Cols", "type": "integer"}, "rows": {"title": "Rows", "type": "integer"}, "reattached": {"title": "Reattached", "type": "boolean"}}, "required": ["terminal_id", "sprites_session_id", "cols", "rows", "reattached"], "title": "PtySessionInfo", "type": "object"}, "AssistantMessageDelta": {"description": "A streaming text fragment from the dev agent. Multiple of these\ninterleave with `ThinkingBlock` and `ToolCallStarted` until the\n`ResultMessage` closes the turn.", "properties": {"type": {"const": "assistant.delta", "default": "assistant.delta", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "text": {"title": "Text", "type": "string"}}, "required": ["chat_id", "seq", "text"], "title": "AssistantMessageDelta", "type": "object"}, "BridgeAssistantMessage": {"description": "Final non-streaming assistant block emitted at turn close. The\nfull text of one assistant message \u2014 used by the user agent (it\nonly sees `important` events, of which this is one).", "properties": {"type": {"const": "assistant.message", "default": "assistant.message", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "text": {"title": "Text", "type": "string"}}, "required": ["chat_id", "seq", "text"], "title": "BridgeAssistantMessage", "type": "object"}, "BridgeErrorEvent": {"description": "Bridge-side errors. `kind` lets the orchestrator route on\nwell-known causes (`clarification_timeout`, `worktree_dirty_externally`,\n`cli_crash`, `cli_pin_mismatch`, ...).", "properties": {"type": {"const": "error", "default": "error", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "kind": {"title": "Kind", "type": "string"}, "message": {"title": "Message", "type": "string"}}, "required": ["chat_id", "seq", "kind", "message"], "title": "BridgeErrorEvent", "type": "object"}, "BridgeFileEditEvent": {"description": "Emitted after `Write` or `Edit` tool calls succeed. `before_sha`\nis null for newly created files.", "properties": {"type": {"const": "file.edit", "default": "file.edit", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "path": {"title": "Path", "type": "string"}, "before_sha": {"anyOf": [{"type": "string"}, {"type": "null"}], "title": "Before Sha"}, "after_sha": {"title": "After Sha", "type": "string"}, "summary": {"title": "Summary", "type": "string"}}, "required": ["chat_id", "seq", "path", "before_sha", "after_sha", "summary"], "title": "BridgeFileEditEvent", "type": "object"}, "BridgePong": {"properties": {"type": {"const": "bridge.pong", "default": "bridge.pong", "title": "Type", "type": "string"}}, "title": "BridgePong", "type": "object"}, "ChatEvicted": {"description": "Bridge evicted this chat's CLI session (LRU cap reached). The\nnext user message will cold-start via `--resume`.", "properties": {"type": {"const": "chat.evicted", "default": "chat.evicted", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "reason": {"enum": ["lru_cap", "idle_grace", "archived", "explicit_cancel"], "title": "Reason", "type": "string"}}, "required": ["chat_id", "seq", "reason"], "title": "ChatEvicted", "type": "object"}, "ChatStarted": {"description": "Emitted when a chat's underlying CLI session reports its\n`claude_session_id` for the first time (via `ResultMessage.session_id`).\nThe orchestrator persists this onto `Chat.claude_session_id` so\nfollow-ups can `--resume` without losing prompt cache.", "properties": {"type": {"const": "chat.started", "default": "chat.started", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "claude_session_id": {"title": "Claude Session Id", "type": "string"}}, "required": ["chat_id", "seq", "claude_session_id"], "title": "ChatStarted", "type": "object"}, "Goodbye": {"description": "Sent by the bridge before a clean shutdown (sprite hibernate /\nprocess exit). Orchestrator can release Redis ownership immediately.", "properties": {"type": {"const": "bridge.goodbye", "default": "bridge.goodbye", "title": "Type", "type": "string"}, "reason": {"title": "Reason", "type": "string"}}, "required": ["reason"], "title": "Goodbye", "type": "object"}, "Hello": {"description": "First frame after WSS handshake. Carries the bridge's view of\n`last_acked_seq_per_chat` so the orchestrator can decide whether to\nrequest replay.", "properties": {"type": {"const": "bridge.hello", "default": "bridge.hello", "title": "Type", "type": "string"}, "bridge_version": {"title": "Bridge Version", "type": "string"}, "last_acked_seq_per_chat": {"additionalProperties": {"type": "integer"}, "title": "Last Acked Seq Per Chat", "type": "object"}}, "required": ["bridge_version"], "title": "Hello", "type": "object"}, "ResultMessage": {"description": "End-of-turn marker from the SDK. Carries the session id (used\nfor `--resume`) and the cumulative usage. The user agent treats\nthis as the \"important conclusion\" event for filter purposes.", "properties": {"type": {"const": "result", "default": "result", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "claude_session_id": {"title": "Claude Session Id", "type": "string"}, "duration_ms": {"title": "Duration Ms", "type": "integer"}, "is_error": {"title": "Is Error", "type": "boolean"}, "error": {"anyOf": [{"type": "string"}, {"type": "null"}], "default": null, "title": "Error"}}, "required": ["chat_id", "seq", "claude_session_id", "duration_ms", "is_error"], "title": "ResultMessage", "type": "object"}, "ShellExecEvent": {"description": "Emitted after `Bash` tool calls finish \u2014 useful for the FE to\nshow `git commit` / test runs / etc. as first-class events instead\nof generic tool calls.", "properties": {"type": {"const": "shell.exec", "default": "shell.exec", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "cmd": {"title": "Cmd", "type": "string"}, "exit_code": {"title": "Exit Code", "type": "integer"}, "stdout_tail": {"title": "Stdout Tail", "type": "string"}, "stderr_tail": {"title": "Stderr Tail", "type": "string"}}, "required": ["chat_id", "seq", "cmd", "exit_code", "stdout_tail", "stderr_tail"], "title": "ShellExecEvent", "type": "object"}, "StatusChange": {"properties": {"type": {"const": "chat.status", "default": "chat.status", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "new_status": {"enum": ["pending", "running", "awaiting_input", "completed", "failed", "cancelled"], "title": "New Status", "type": "string"}}, "required": ["chat_id", "seq", "new_status"], "title": "StatusChange", "type": "object"}, "ThinkingBlock": {"description": "Extended-thinking block. Filtered out from the user-agent stream\n(too noisy for Haiku) but rendered on the FE.", "properties": {"type": {"const": "thinking", "default": "thinking", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "text": {"title": "Text", "type": "string"}}, "required": ["chat_id", "seq", "text"], "title": "ThinkingBlock", "type": "object"}, "TokenUsageEvent": {"description": "Per-`ResultMessage.usage` deltas. Per-chat budget enforcement\nlives in slice 8b \u2014 slice 8 emits warning events at 80%.", "properties": {"type": {"const": "token.usage", "default": "token.usage", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "input_delta": {"title": "Input Delta", "type": "integer"}, "output_delta": {"title": "Output Delta", "type": "integer"}, "cache_creation_delta": {"default": 0, "title": "Cache Creation Delta", "type": "integer"}, "cache_read_delta": {"default": 0, "title": "Cache Read Delta", "type": "integer"}}, "required": ["chat_id", "seq", "input_delta", "output_delta"], "title": "TokenUsageEvent", "type": "object"}, "ToolCallFinished": {"properties": {"type": {"const": "tool.finished", "default": "tool.finished", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "tool_use_id": {"title": "Tool Use Id", "type": "string"}, "is_error": {"default": false, "title": "Is Error", "type": "boolean"}, "result_preview": {"title": "Result Preview", "type": "string"}}, "required": ["chat_id", "seq", "tool_use_id", "result_preview"], "title": "ToolCallFinished", "type": "object"}, "ToolCallStarted": {"properties": {"type": {"const": "tool.started", "default": "tool.started", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "tool_use_id": {"title": "Tool Use Id", "type": "string"}, "tool_name": {"title": "Tool Name", "type": "string"}, "args": {"additionalProperties": true, "title": "Args", "type": "object"}}, "required": ["chat_id", "seq", "tool_use_id", "tool_name", "args"], "title": "ToolCallStarted", "type": "object"}, "UserAgentSuggestion": {"description": "The user agent (BE) decided to auto-answer the dev agent's most\nrecent question. Informational frame for the FE \u2014 it shows the\nsuggested reply with a countdown to `override_deadline_at`. If the\nuser doesn't override, the orchestrator sends the suggested reply\nas a normal `UserMessage` to the bridge after the deadline.\n\nNo round-trip needed at the bridge level \u2014 clarifications are just\nnatural assistant text + next user message.", "properties": {"type": {"const": "user_agent.suggestion", "default": "user_agent.suggestion", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "suggestion_id": {"title": "Suggestion Id", "type": "string"}, "suggested_reply": {"title": "Suggested Reply", "type": "string"}, "reason": {"title": "Reason", "type": "string"}, "override_deadline_at": {"title": "Override Deadline At", "type": "string"}}, "required": ["chat_id", "seq", "suggestion_id", "suggested_reply", "reason", "override_deadline_at"], "title": "UserAgentSuggestion", "type": "object"}, "Ack": {"description": "Periodic acknowledgement of `(chat_id, ack_seq)`. The bridge\ndrops persisted frames from its ring buffer up to `ack_seq` for the\ngiven chat.", "properties": {"type": {"const": "bridge.ack", "default": "bridge.ack", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "ack_seq": {"title": "Ack Seq", "type": "integer"}}, "required": ["chat_id", "ack_seq"], "title": "Ack", "type": "object"}, "BridgePing": {"properties": {"type": {"const": "bridge.ping", "default": "bridge.ping", "title": "Type", "type": "string"}}, "title": "BridgePing", "type": "object"}, "CancelChat": {"description": "Hard interrupt: bridge calls `client.interrupt()` then closes.", "properties": {"type": {"const": "bridge.cancel", "default": "bridge.cancel", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "frame_id": {"title": "Frame Id", "type": "string"}}, "required": ["chat_id", "frame_id"], "title": "CancelChat", "type": "object"}, "ChatState": {"description": "Reconciliation message the orchestrator sends in response to\n`Hello` \u2014 declares the canonical state for each chat the bridge\nreported. Used to converge after a reconnect.\n\n`last_seen_seq` tells the bridge \"this is the highest seq I have\npersisted for this chat; resend anything beyond.\" A bridge with\nfewer frames than this can recover via Mongo replay (no-op locally).", "properties": {"type": {"const": "bridge.chat_state", "default": "bridge.chat_state", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "last_seen_seq": {"title": "Last Seen Seq", "type": "integer"}, "claude_session_id": {"anyOf": [{"type": "string"}, {"type": "null"}], "default": null, "title": "Claude Session Id"}}, "required": ["chat_id", "last_seen_seq"], "title": "ChatState", "type": "object"}, "PauseChat": {"description": "Soft pause: bridge stops feeding turns until `UserMessage` or\n`CancelChat` arrives. Slice 8 doesn't surface this in the UI but\nthe wire variant is reserved.", "properties": {"type": {"const": "bridge.pause", "default": "bridge.pause", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "frame_id": {"title": "Frame Id", "type": "string"}}, "required": ["chat_id", "frame_id"], "title": "PauseChat", "type": "object"}, "SessionEnv": {"description": "Reserved for v1+ user-scoped credentials (OAuth / BYOK). v1\nbridges receive this and ignore the contents \u2014 `extra=\"ignore\"`\nkeeps them forward-compatible. Declared in the union so the\nschema is stable.", "properties": {"type": {"const": "bridge.session_env", "default": "bridge.session_env", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "frame_id": {"title": "Frame Id", "type": "string"}, "env": {"additionalProperties": {"type": "string"}, "title": "Env", "type": "object"}}, "required": ["chat_id", "frame_id"], "title": "SessionEnv", "type": "object"}, "UserMessage": {"description": "User-sent (or user-agent-enhanced) prompt for a chat. First\nmessage: `claude_session_id=None` and the bridge spawns a fresh\n`ClaudeSDKClient`. Follow-ups: the bridge feeds text to the live\nclient OR `--resume`s if cold.", "properties": {"type": {"const": "bridge.user_message", "default": "bridge.user_message", "title": "Type", "type": "string"}, "chat_id": {"title": "Chat Id", "type": "string"}, "frame_id": {"title": "Frame Id", "type": "string"}, "text": {"title": "Text", "type": "string"}, "claude_session_id": {"anyOf": [{"type": "string"}, {"type": "null"}], "default": null, "title": "Claude Session Id"}}, "required": ["chat_id", "frame_id", "text"], "title": "UserMessage", "type": "object"}, "OrchestratorToWeb": {"discriminator": {"mapping": {"backpressure.warning": "#/definitions/BackpressureWarning", "debug.event": "#/definitions/DebugEvent", "error": "#/definitions/ErrorEvent", "ping": "#/definitions/ServerPing", "pong": "#/definitions/Pong", "sandbox.status": "#/definitions/SandboxStatusEvent", "status.change": "#/definitions/StatusChangeEvent"}, "propertyName": "type"}, "oneOf": [{"$ref": "#/definitions/StatusChangeEvent"}, {"$ref": "#/definitions/SandboxStatusEvent"}, {"$ref": "#/definitions/ErrorEvent"}, {"$ref": "#/definitions/BackpressureWarning"}, {"$ref": "#/definitions/DebugEvent"}, {"$ref": "#/definitions/Pong"}, {"$ref": "#/definitions/ServerPing"}]}, "WebToOrchestrator": {"discriminator": {"mapping": {"ping": "#/definitions/ClientPing", "pong": "#/definitions/ClientPong", "resume": "#/definitions/Resume"}, "propertyName": "type"}, "oneOf": [{"$ref": "#/definitions/Resume"}, {"$ref": "#/definitions/ClientPing"}, {"$ref": "#/definitions/ClientPong"}]}, "FsWatchToWeb": {"discriminator": {"mapping": {"file.edit": "#/definitions/FileEditEvent", "fswatch.subscribed": "#/definitions/FsWatchSubscribed"}, "propertyName": "type"}, "oneOf": [{"$ref": "#/definitions/FileEditEvent"}, {"$ref": "#/definitions/FsWatchSubscribed"}]}, "WebToPty": {"discriminator": {"mapping": {"pty.close": "#/definitions/RequestClosePty", "pty.open": "#/definitions/RequestOpenPty", "pty.resize": "#/definitions/ResizePty"}, "propertyName": "type"}, "oneOf": [{"$ref": "#/definitions/ResizePty"}, {"$ref": "#/definitions/RequestOpenPty"}, {"$ref": "#/definitions/RequestClosePty"}]}, "PtyToWeb": {"discriminator": {"mapping": {"pty.exit": "#/definitions/PtyExit", "pty.session_info": "#/definitions/PtySessionInfo"}, "propertyName": "type"}, "oneOf": [{"$ref": "#/definitions/PtySessionInfo"}, {"$ref": "#/definitions/PtyExit"}]}, "BridgeToOrchestrator": {"discriminator": {"mapping": {"assistant.delta": "#/definitions/AssistantMessageDelta", "assistant.message": "#/definitions/BridgeAssistantMessage", "bridge.goodbye": "#/definitions/Goodbye", "bridge.hello": "#/definitions/Hello", "bridge.pong": "#/definitions/BridgePong", "chat.evicted": "#/definitions/ChatEvicted", "chat.started": "#/definitions/ChatStarted", "chat.status": "#/definitions/StatusChange", "error": "#/definitions/BridgeErrorEvent", "file.edit": "#/definitions/BridgeFileEditEvent", "result": "#/definitions/ResultMessage", "shell.exec": "#/definitions/ShellExecEvent", "thinking": "#/definitions/ThinkingBlock", "token.usage": "#/definitions/TokenUsageEvent", "tool.finished": "#/definitions/ToolCallFinished", "tool.started": "#/definitions/ToolCallStarted", "user_agent.suggestion": "#/definitions/UserAgentSuggestion"}, "propertyName": "type"}, "oneOf": [{"$ref": "#/definitions/Hello"}, {"$ref": "#/definitions/Goodbye"}, {"$ref": "#/definitions/BridgePong"}, {"$ref": "#/definitions/ChatStarted"}, {"$ref": "#/definitions/ChatEvicted"}, {"$ref": "#/definitions/StatusChange"}, {"$ref": "#/definitions/AssistantMessageDelta"}, {"$ref": "#/definitions/BridgeAssistantMessage"}, {"$ref": "#/definitions/ThinkingBlock"}, {"$ref": "#/definitions/ToolCallStarted"}, {"$ref": "#/definitions/ToolCallFinished"}, {"$ref": "#/definitions/BridgeFileEditEvent"}, {"$ref": "#/definitions/ShellExecEvent"}, {"$ref": "#/definitions/TokenUsageEvent"}, {"$ref": "#/definitions/UserAgentSuggestion"}, {"$ref": "#/definitions/ResultMessage"}, {"$ref": "#/definitions/BridgeErrorEvent"}]}, "OrchestratorToBridge": {"discriminator": {"mapping": {"bridge.ack": "#/definitions/Ack", "bridge.cancel": "#/definitions/CancelChat", "bridge.chat_state": "#/definitions/ChatState", "bridge.pause": "#/definitions/PauseChat", "bridge.p