{"$schema": "http://json-schema.org/draft-07/schema#", "title": "OctoCanvasWireProtocol", "definitions": {"BackpressureWarning": {"description": "Emitted when the per-subscriber outbound queue overflows. The web\nclient's reconnect logic should treat this as a hint to bump its replay\ncursor and `Resume` from `last_dropped_seq` on next reconnect.", "properties": {"type": {"const": "backpressure.warning", "default": "backpressure.warning", "title": "Type", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "last_dropped_seq": {"title": "Last Dropped Seq", "type": "integer"}}, "required": ["seq", "last_dropped_seq"], "title": "BackpressureWarning", "type": "object"}, "DebugEvent": {"description": "Slice 5a only \u2014 produced by the dev-only `/api/_internal/...` inject\nendpoint. The full agent event taxonomy replaces this in slice 6+.", "properties": {"type": {"const": "debug.event", "default": "debug.event", "title": "Type", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "message": {"title": "Message", "type": "string"}}, "required": ["seq", "message"], "title": "DebugEvent", "type": "object"}, "ErrorEvent": {"properties": {"type": {"const": "error", "default": "error", "title": "Type", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "kind": {"title": "Kind", "type": "string"}, "message": {"title": "Message", "type": "string"}}, "required": ["seq", "kind", "message"], "title": "ErrorEvent", "type": "object"}, "Pong": {"description": "Reply to a `Ping` from the web client. Carries `nonce` for correlation\nso the web side can compute round-trip latency. No `seq` \u2014 system frame.", "properties": {"type": {"const": "pong", "default": "pong", "title": "Type", "type": "string"}, "nonce": {"title": "Nonce", "type": "string"}}, "required": ["nonce"], "title": "Pong", "type": "object"}, "SandboxStatusEvent": {"properties": {"type": {"const": "sandbox.status", "default": "sandbox.status", "title": "Type", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "sandbox_id": {"title": "Sandbox Id", "type": "string"}, "status": {"enum": ["provisioning", "cold", "warm", "running", "resetting", "destroyed", "failed"], "title": "Status", "type": "string"}, "public_url": {"anyOf": [{"type": "string"}, {"type": "null"}], "default": null, "title": "Public Url"}}, "required": ["seq", "sandbox_id", "status"], "title": "SandboxStatusEvent", "type": "object"}, "ServerPing": {"description": "Server-initiated heartbeat. The web client must reply with `Pong` (see\n`commands.py`). No `seq` \u2014 system frame.", "properties": {"type": {"const": "ping", "default": "ping", "title": "Type", "type": "string"}, "nonce": {"title": "Nonce", "type": "string"}}, "required": ["nonce"], "title": "ServerPing", "type": "object"}, "StatusChangeEvent": {"properties": {"type": {"const": "status.change", "default": "status.change", "title": "Type", "type": "string"}, "seq": {"title": "Seq", "type": "integer"}, "new_status": {"enum": ["pending", "running", "completed", "failed", "cancelled"], "title": "New Status", "type": "string"}}, "required": ["seq", "new_status"], "title": "StatusChangeEvent", "type": "object"}, "ClientPing": {"properties": {"type": {"const": "ping", "default": "ping", "title": "Type", "type": "string"}, "nonce": {"title": "Nonce", "type": "string"}}, "required": ["nonce"], "title": "ClientPing", "type": "object"}, "ClientPong": {"properties": {"type": {"const": "pong", "default": "pong", "title": "Type", "type": "string"}, "nonce": {"title": "Nonce", "type": "string"}}, "required": ["nonce"], "title": "ClientPong", "type": "object"}, "Resume": {"description": "Sent as the FIRST frame of every (re)connection. The orchestrator\nstreams every event with `seq > after_seq` from Mongo, then transitions\nto live mode by subscribing to the per-task fanout channel.", "properties": {"type": {"const": "resume", "default": "resume", "title": "Type", "type": "string"}, "after_seq": {"title": "After Seq", "type": "integer"}}, "required": ["after_seq"], "title": "Resume", "type": "object"}, "OrchestratorToWeb": {"discriminator": {"mapping": {"backpressure.warning": "#/definitions/BackpressureWarning", "debug.event": "#/definitions/DebugEvent", "error": "#/definitions/ErrorEvent", "ping": "#/definitions/ServerPing", "pong": "#/definitions/Pong", "sandbox.status": "#/definitions/SandboxStatusEvent", "status.change": "#/definitions/StatusChangeEvent"}, "propertyName": "type"}, "oneOf": [{"$ref": "#/definitions/StatusChangeEvent"}, {"$ref": "#/definitions/SandboxStatusEvent"}, {"$ref": "#/definitions/ErrorEvent"}, {"$ref": "#/definitions/BackpressureWarning"}, {"$ref": "#/definitions/DebugEvent"}, {"$ref": "#/definitions/Pong"}, {"$ref": "#/definitions/ServerPing"}]}, "WebToOrchestrator": {"discriminator": {"mapping": {"ping": "#/definitions/ClientPing", "pong": "#/definitions/ClientPong", "resume": "#/definitions/Resume"}, "propertyName": "type"}, "oneOf": [{"$ref": "#/definitions/Resume"}, {"$ref": "#/definitions/ClientPing"}, {"$ref": "#/definitions/ClientPong"}]}}}
