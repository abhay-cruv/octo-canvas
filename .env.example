# Mongo (orchestrator + bridge)
MONGODB_URI=mongodb://localhost:27017/octo_canvas

# Redis (orchestrator)
REDIS_URL=redis://localhost:6379

# Sessions (orchestrator)
AUTH_SECRET=changeme-generate-with-openssl-rand-base64-32

# GitHub OAuth App — user identity AND repo access (slices 1 + 2)
# Scope requested: read:user user:email repo
# See README "Setting up GitHub OAuth (local dev)"
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Sandbox provisioning (orchestrator, slice 4) — Sprites SDK
# SANDBOX_PROVIDER picks the backend. "sprites" requires SPRITES_TOKEN.
# "mock" is for local dev; emits a warning every boot. Empty SPRITES_TOKEN with
# SANDBOX_PROVIDER=sprites aborts startup — there is NO silent fallback.
# Resources, regions, idle hibernation, and the sprite image are all managed
# by Sprites itself — we don't configure them here.
SANDBOX_PROVIDER=mock
SPRITES_TOKEN=
SPRITES_BASE_URL=https://api.sprites.dev

# Anthropic (bridge)
ANTHROPIC_API_KEY=

# Object storage (orchestrator) — for agent run event logs
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Service URLs
ORCHESTRATOR_PORT=3001
WEB_BASE_URL=http://localhost:5173
ORCHESTRATOR_BASE_URL=http://localhost:3001
VITE_ORCHESTRATOR_BASE_URL=http://localhost:3001
